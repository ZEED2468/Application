# =============================================================================
# JD Engine — THE central env file (one file drives the whole stack).
#
# Copy it and point compose at it:
#   cp infra/.env.example .env                 # default location (repo root)
#   make up                                    # uses ./.env
#   make up ENV=/opt/jd/prod.env               # uses a custom file
#   # or directly:
#   ENV_FILE=/opt/jd/prod.env docker compose --env-file /opt/jd/prod.env \
#     -f infra/docker-compose.yml -f infra/docker-compose.nginx.yml up -d
#
# NOTE: the network-critical vars (DATABASE_URL / REDIS_URL / CELERY_* /
# BRIDGE_BASE_URL / API_BASE_URL / BACKEND_URL) are PINNED to in-network service
# names inside docker-compose.yml, so their values here only matter for host-run
# (non-docker) dev. Everything else below is injected into the containers as-is.
# =============================================================================

# --- Core --------------------------------------------------------------------
ENVIRONMENT=development          # set to "production" on the server (see note in infra/nginx/README.md)
DEBUG=true

# --- Datastores --------------------------------------------------------------
# Compose overrides these to postgres:5432 / redis:6379. Values here are for
# host-run dev (the compose ports are published on 5433 / 6380).
DATABASE_URL=postgresql+asyncpg://jd:jd@localhost:5433/jd
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# --- Auth / signing secrets  (CHANGE THESE IN PROD) --------------------------
JWT_SECRET=change-me-in-prod
COOKIE_SECURE=false              # keep false on Cloudflare Flexible; true on Full(strict)/direct-HTTPS
# COOKIE_DOMAIN=.quickbiteltd.org  # only if you serve web+api on different subdomains and need shared cookies
BRIDGE_HMAC_SECRET=change-me-bridge
RESEND_WEBHOOK_SECRET=change-me-resend

# --- Integrations ------------------------------------------------------------
# Leave keys blank in dev: with USE_FAKE_INTEGRATIONS=true the app uses local
# fakes instead of calling out. Fill in to exercise real providers.
USE_FAKE_INTEGRATIONS=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
RESEND_API_KEY=
APOLLO_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
SERPAPI_API_KEY=

# --- Cloudflare R2 (CV / artifact storage, S3-compatible) --------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jd-cvs
R2_ENDPOINT=

# --- Service URLs (compose pins these; values here are for host-run) ---------
BRIDGE_BASE_URL=http://localhost:8081
# Web → API. Compose pins BACKEND_URL to http://api:8000 inside the network.
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE=http://localhost:8000

# --- Email warm-up governor --------------------------------------------------
WEEKLY_CAP_PER_HUNTER=20
