# JD Engine — environment template.
#
# Copy this to the repo root as `.env` (compose reads ../.env):
#   cp infra/.env.example .env
#
# Dev defaults are safe to commit-free use; real credentials drop into the
# integration + R2 + email sections below (see infra/README.md).

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true

# ---------------------------------------------------------------------------
# Datastores
# Hosts below are compose service names. For host-run dev (no compose) swap to
# localhost:5432 / localhost:6379.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://jd:jd@postgres:5432/jd
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------------------------------------------------------------------------
# Auth / signing secrets  (CHANGE THESE IN PROD)
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-in-prod
COOKIE_SECURE=false

# Shared HMAC secrets between services / inbound webhooks.
BRIDGE_HMAC_SECRET=change-me-bridge
RESEND_WEBHOOK_SECRET=change-me-resend

# ---------------------------------------------------------------------------
# Integrations
# Leave keys blank in dev: with USE_FAKE_INTEGRATIONS=true the app uses local
# fakes instead of calling out. Fill in to exercise real providers.
# ---------------------------------------------------------------------------
USE_FAKE_INTEGRATIONS=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
RESEND_API_KEY=
APOLLO_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
SERPAPI_API_KEY=

# ---------------------------------------------------------------------------
# Cloudflare R2 (CV / artifact storage, S3-compatible)
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jd-cvs
R2_ENDPOINT=

# ---------------------------------------------------------------------------
# Service URLs (compose-internal hostnames)
# ---------------------------------------------------------------------------
BRIDGE_BASE_URL=http://wa-bridge:8081
# Browser-facing API base (used by the web app at build/runtime in the browser).
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Server-to-server API base (web server -> api inside the compose network).
BACKEND_URL=http://api:8000

# ---------------------------------------------------------------------------
# Email warm-up governor
# ---------------------------------------------------------------------------
WEEKLY_CAP_PER_HUNTER=20
