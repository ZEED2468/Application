# =============================================================================
# Backend (FastAPI) environment — every variable app/config.py reads.
#
# Host-run dev:  cp .env.example .env   (config.py auto-loads ./.env)
# Docker compose: provided via the central file (infra/.env.example) — and the
#                 network-critical vars (DATABASE_URL/REDIS/CELERY/BRIDGE_BASE_URL)
#                 are PINNED to service names in infra/docker-compose.yml.
# Render:         set these as the service's Environment Variables.
# =============================================================================

# --- Core --------------------------------------------------------------------
ENVIRONMENT=development          # "production" on a real deploy
DEBUG=true

# --- Database ----------------------------------------------------------------
# postgres:// is auto-normalized to postgresql+asyncpg:// (Render/Heroku style).
# Host-run against the compose Postgres uses localhost:5433.
DATABASE_URL=postgresql+asyncpg://jd:jd@localhost:5432/jd

# --- Redis / Celery ----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Auth / cookies ----------------------------------------------------------
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=false              # true over HTTPS; forced true when SameSite=none
COOKIE_SAMESITE=lax              # "none" if the browser calls the API cross-site
# COOKIE_DOMAIN=.quickbiteltd.org  # only for sharing cookies across subdomains

# --- CORS (only when the browser calls the API directly) ---------------------
# Comma-separated EXACT origins — scheme + host, NO trailing slash.
CORS_ORIGINS=
# e.g. CORS_ORIGINS=https://jd.quickbiteltd.org,https://application-eight-phi.vercel.app

# --- HMAC shared secrets (bridge + webhook signatures) -----------------------
BRIDGE_HMAC_SECRET=change-me-bridge
RESEND_WEBHOOK_SECRET=change-me-resend

# --- LLM provider (one global default; swap provider by changing 4 vars) ------
# Set USE_FAKE_INTEGRATIONS=false below or AI features stay offline.
#
# Supported providers: anthropic | openai | google
#   openai = any OpenAI-compatible API (Cohere, Groq, OpenRouter, Ollama, …)
#
# Per-feature overrides (optional): LLM_<FEATURE>_{PROVIDER,MODEL,API_KEY,BASE_URL}
# Features: tailoring, cover_letter, hookfinder, draft_email, classify_reply,
# ats_vet, ats_analyze, cv_structure, track_classify
#
# --- Cohere (now) — uses the OpenAI-compatible adapter -----------------------
USE_FAKE_INTEGRATIONS=false
LLM_PROVIDER=openai
LLM_API_KEY=your-cohere-api-key
LLM_BASE_URL=https://api.cohere.ai/compatibility/v1
LLM_MODEL=command-r7b-12-2024
#
# --- Gemini (later) — comment Cohere block above, uncomment below ------------
# LLM_PROVIDER=google
# LLM_API_KEY=your-google-ai-studio-key
# LLM_MODEL=gemini-2.0-flash
# LLM_BASE_URL=
#
# --- Anthropic (alternative) ---------------------------------------------------
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your-anthropic-key
# LLM_MODEL=claude-opus-4-8
# LLM_BASE_URL=

# Legacy Anthropic names (only used when LLM_PROVIDER=anthropic and LLM_API_KEY is blank)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
RESEND_API_KEY=
APOLLO_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
SERPAPI_API_KEY=

# --- Cloudflare R2 (CV / artifact storage, S3-compatible) --------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jd-cvs
R2_ENDPOINT=

# --- WhatsApp bridge ---------------------------------------------------------
BRIDGE_BASE_URL=http://localhost:8081

# --- Behaviour ---------------------------------------------------------------
WEEKLY_CAP_PER_HUNTER=20
# true = no real LLM/email/job APIs (dev default). false = use keys above.
USE_FAKE_INTEGRATIONS=true
