# Core
ENVIRONMENT=development
DEBUG=true

# Database / Redis (compose service names; use localhost:5433 / :6380 for host-run dev)
# Render: link a Postgres DB and set DATABASE_URL to its *Internal* URL
# (postgres://... works — converted to postgresql+asyncpg:// automatically).
DATABASE_URL=postgresql+asyncpg://jd:jd@postgres:5432/jd
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth
JWT_SECRET=change-me-in-prod
COOKIE_SECURE=false

# HMAC shared secrets
BRIDGE_HMAC_SECRET=change-me-bridge
RESEND_WEBHOOK_SECRET=change-me-resend

# Integrations (blank in dev -> fakes used)
USE_FAKE_INTEGRATIONS=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
RESEND_API_KEY=
APOLLO_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
SERPAPI_API_KEY=

# R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jd-cvs
R2_ENDPOINT=

# Bridge
BRIDGE_BASE_URL=http://bridge:8081

# Email warm-up
WEEKLY_CAP_PER_HUNTER=20
