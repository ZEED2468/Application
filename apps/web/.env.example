# The web app reaches the FastAPI backend one of two ways:
#
# 1) PROXY (recommended on Vercel) — leave NEXT_PUBLIC_API_BASE unset.
#    Browser → this app's /api/* → BACKEND_URL/api/*
#    Set on Vercel (server-side only, then redeploy):
#    BACKEND_URL=https://application-yye1.onrender.com
#
# 2) DIRECT — browser calls the API directly (cross-origin).
#    Set on Vercel (redeploy after):
#    NEXT_PUBLIC_API_BASE=https://application-yye1.onrender.com
#    On Render API also set:
#    CORS_ORIGINS=https://application-eight-phi.vercel.app
#    COOKIE_SAMESITE=none
#    COOKIE_SECURE=true
#
# Local development defaults BACKEND_URL to http://localhost:8000 via lib/env.ts.
BACKEND_URL=http://localhost:8000
