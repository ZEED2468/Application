# The web app reaches the FastAPI backend one of two ways:
#
# 1) DIRECT (browser → backend, cross-origin) — set this PUBLIC build-time var to
#    the backend's base URL. The browser calls it directly; the backend must allow
#    the frontend origin via CORS_ORIGINS and set cross-site cookies (COOKIE_SAMESITE).
#    Vercel: Settings → Environment Variables → NEXT_PUBLIC_API_BASE (redeploy after).
NEXT_PUBLIC_API_BASE=https://jd-be.quickbiteltd.org
#
# 2) PROXY (browser → this app's /api → backend) — leave NEXT_PUBLIC_API_BASE unset
#    and set BACKEND_URL (server-side only) instead. Same-origin cookies, no CORS.
# BACKEND_URL=http://localhost:8000
